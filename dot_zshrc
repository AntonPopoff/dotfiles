# Add local binaries to path
if [[ -d "$HOME/.local/bin" ]]; then
    path+="$HOME/local/.bin"
fi

# Load and enable zsh autocompletion module
autoload -Uz compinit && compinit

# Improve autocompletion menu
zstyle ':completion:*' menu select                  # Make the menu navigable with arrow keys
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}' # Case-insensitive completion

# Setup zsh history files and size
HISTFILE="$HOME/.zsh_history"
HISTSIZE=10000
SAVEHIST=10000
setopt SHARE_HISTORY        # Share zsh history across all sessions
setopt HIST_IGNORE_ALL_DUPS # Delete old recorded entry if new entry is a duplicate
setopt HIST_IGNORE_SPACE    # Don't record entries starting with a space
setopt HIST_REDUCE_BLANKS   # Prevent irrelevant whitespace from being added to the history

# Load zsh VCS module for git branch prompt
autoload -Uz vcs_info

# Setup vcs_info module to output git branch name
precmd() { vcs_info }
zstyle ':vcs_info:*' enable git                  # Enable git repo checking
zstyle ':vcs_info:git:*' formats '%F{34}[%b]%f ' # Output only branch name

# Set custom zsh prompt
setopt PROMPT_SUBST

# Custom prompt with custom colors and git branch name
PROMPT='%B%F{blue}%~%f ${vcs_info_msg_0_}>%b '

# Setup zoxide and set it's alias to cd
if command -v zoxide &> /dev/null; then
    eval "$(zoxide init zsh)"
    alias cd='z'
fi

# Setup eza's alias
if command -v eza &> /dev/null; then
    alias ls='eza --long --all'
fi

# Setup btop's alias
if command -v btop &> /dev/null; then
    alias top='btop'
fi

# Setup nvim's alias
if command -v nvim &> /dev/null; then
    alias vi='nvim'
    alias vim='nvim'
fi

# Setup bat's alias and defautl values
if command -v bat &> /dev/null; then
    export BAT_STYLE='plain'
    export BAT_THEME='ansi'
    alias cat='bat'
fi

# Fzf setup and custom commands
if command -v fzf &> /dev/null; then
    source <(fzf --zsh)

    # Setting fd as the default source for fzf
    export FZF_DEFAULT_COMMAND='fd --type f --strip-cwd-prefix --no-ignore'

    # Apply the default command to CTRL-T as well
    export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"

    # Use fd for generating path candidates for the ** trigger
    _fzf_compgen_path() {
        fd --hidden --exclude .git . "$1"
    }

    # Use fd for generating directory candidates for the ** trigger
    _fzf_compgen_dir() {
        fd --type d --hidden --exclude .git . "$1"
    }

    if [[ -f "$HOME/.zsh/fzf-git.sh/fzf-git.sh" ]]; then
        source "$HOME/.zsh/fzf-git.sh/fzf-git.sh"

        # Remap fzf git branches command so it won't clash with tmux
        bindkey '^Gb' fzf-git-branches-widget  # Ctrl-g + b

        # Define cat command for preview window
        if command -v bat &> /dev/null; then
            FZF_GIT_CAT='bat --color=always'
        fi
    fi
fi

# Enter tmux session on startup
if [[ -z "$TMUX" && -n "$PS1" ]] && command -v tmux &> /dev/null; then
    tmux attach-session || tmux new-session
fi

